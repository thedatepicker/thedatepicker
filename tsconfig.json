{
	"compilerOptions": {
		"target": "ES2016",
		"module": "Node16",
		"moduleResolution": "Node16",
		"esModuleInterop": true,
		"noImplicitAny": true,
		"removeComments": true,
		"preserveConstEnums": true,
		"rootDir": "./src/",
		"declaration": true,
		"declarationDir": "amd",
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"strict": false
	},
	"include": ["src"]
}
