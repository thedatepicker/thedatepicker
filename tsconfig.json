{
	"compilerOptions": {
		"target": "ES2015",
		"strict": false,
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"esModuleInterop": true,
		"noImplicitAny": true,
		"removeComments": true,
		"preserveConstEnums": true,
		"rootDir": "./src/",
		"declaration": true,
		"declarationDir": "amd",
		"forceConsistentCasingInFileNames": true
	},
	"include": ["src"]
}
